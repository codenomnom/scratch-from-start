}
article.about {
  height: 0;
  overflow: hidden;
  background-color: #ffd166;
  transition: height 0.3s ease;
}
article.about .about-wrapper {
  width: 800px;
  justify-content: flex-start;
}
article.about:target {
  height: 50vh;
}
section.intro, .intro {
  position: relative;
  justify-content: flex-start;
  flex-direction: column;
  min-height: 65vh;
  margin-bottom: 40px;
  font-family: "Montserrat", sans-serif;
  font-size: 14px;
  font-weight: 500;
}
section.intro-logo, .intro-logo {
  position: absolute;
  top: 27px;
  left: -44px;
}
section.intro p, .intro p {
  margin-block-end: 0.5rem;
}
h1 {
  margin-bottom: 40px;
}
nav {
  padding: 0 10%;
}
nav .chapter {
  flex: 1;
  display: flex;
  justify-content: center;
  margin: 0 2%;
}
nav .chapter-container ul, nav .chapter-container ol {
  list-style: none;
}
nav .chapter-container ul {
  padding-inline-start: 0;
}
nav .chapter-container ol {
  padding-inline-start: 26px;
  font-family: "Montserrat", sans-serif;
  font-size: 14px;
  font-weight: 500;
}
nav .chapter-container a:hover {
  text-decoration: underline;
}
nav .chapter-container a:hover:before {
  display: none;
}
@media (max-width: 1399px) {
  nav section.chapter {
    margin: 0 1%;
  }
}
@media (max-width: 1199px) {
  nav {
    flex-wrap: wrap;
  }
  nav section.chapter {
    flex-basis: 50%;
    margin: 0;
  }
  nav section.filler {
    flex-basis: 50%;
  }
}
@media (max-width: 767px) {
  nav section.chapter {
    flex-basis: 100%;
  }
}
@media (max-width: 1599px) {
  nav {
    padding: 0 6%;
  }
}
@media (max-width: 1399px) {
  nav {
    padding: 0 3%;
  }
}
@media (max-width: 1199px) {
  nav {
    padding: 0 2%;
  }
}
section article article {
  padding-left: 20px;
}
section article article h5 {
  margin-block-end: 0.5rem;
}
section article article > p {
  margin-block-start: 0;
}
.chip {
  display: inline-block;
  height: 19px;
  position: relative;
  margin-left: 2px;
  padding: 0 5px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
  line-height: 20px;
  white-space: nowrap;
  font-style: normal;
  color: #073b4c;
  transition: border-color 0.3s ease;
}
.chip.l1 {
  background-color: #ef476f;
}
.chip.l2 {
  background-color: #ACCBE0;
}
.chip.l3 {
  background-color: #ffd166;
}
em {
  display: inline-block;
  width: 8px;
  height: 8px;
  position: relative;
  margin-left: 2px;
  padding: 0;
  border-radius: 50%;
  border: 1px solid #f5f5f5;
  font-size: 0;
  line-height: 20px;
  white-space: nowrap;
  color: #073b4c;
  cursor: help;
  transition: border-color 0.3s ease;
}
em:after {
  display: inline-block;
  height: 19px;
  position: relative;
  margin-left: 2px;
  padding: 0 5px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 500;
  line-height: 20px;
  white-space: nowrap;
  font-style: normal;
  color: #073b4c;
  transition: border-color 0.3s ease;
  background: inherit;
  top: -50%;
  content: attr(data-help);
  display: block;
  left: calc(100% + 8px);
  position: absolute;
  z-index: 1;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}
em:hover:after {
  opacity: 1;
}
em.l1 {
  background-color: #ef476f;
}
em.l1:hover {
  border-color: #ef476f;
}
em.l2 {
  background-color: #ACCBE0;
}
em.l2:hover {
  border-color: #ACCBE0;
}
em.l3 {
  background-color: #ffd166;
}
em.l3:hover {
  border-color: #ffd166;
}
aside {
  position: fixed;
  font-size: 12px;
}
aside.top {
  top: 10px;
}
aside.left {
  left: 10px;
}
aside.right {
  right: 10px;
}
aside.bottom {
  bottom: 10px;
}
aside.top.right, aside.bottom.left {
  display: flex;
  flex-direction: column;
}
aside.top.right a, aside.bottom.left a {
  opacity: 0.5;
  margin-bottom: 2px;
}
aside.top.right a img, aside.bottom.left a img {
  width: 21px;
  height: 21px;
}
aside.top.right a:hover, aside.bottom.left a:hover {
  opacity: 1;
}
aside.bottom.right {
  bottom: 2px;
  right: 6px;
}
code {
  padding: 3px 5px;
  background: #E8E8E8;
  border-radius: 2px;
  font-size: 15px;
}
pre code {
  display: block;
  white-space: pre-line;
  max-width: 100%;
  min-width: 100px;
  padding: 4px 8px;
  border-radius: 4px;
}
pre code i {
  color: #8d8d91;
}
html {
  scroll-behavior: smooth;
}
body {
  font-family: "Catamaran", sans-serif;
  font-size: 17px;
  color: #0D112B;
  line-height: 26px;
  position: relative;
  background-color: #f5f5f5;
}
.column {
  margin-left: auto;
  margin-right: auto;
  display: flex;
  justify-content: center;
}
.mw800 {
  max-width: 800px;
}
.mw1000 {
  max-width: 1000px;
}
main {
  margin-top: 100px;
}
main.column {
  justify-content: flex-start;
}
@media print {
  nav {
    flex-wrap: wrap;
    /* TODO: move to main.css? */
  }

  nav section {
    flex-basis: 100%;
  }
}
