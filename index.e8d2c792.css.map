h1, h2, h3, h4, h5, h6 {
  font-family: "Montserrat", sans-serif;
  font-weight: 800;
  position: relative;
  width: fit-content;
}
h1 {
  font-size: 28px;
  line-height: 48px;
}
h1:before, h1:before, h1:before {
  content: "";
  background-color: #ffdd00;
  /*opacity: 0.102;*/
  z-index: -1;
  width: 100%;
  height: 8px;
  position: absolute;
  bottom: 2px;
  bottom: 10px;
  left: 0;
  border-radius: 4px;
  opacity: 0;
}
h2, h3 {
  margin-block-end: 2rem;
}
h4 {
  margin-block-end: 0.4em;
}
p {
  /*margin: 0;*/
}
p.note {
  font-style: italic;
  font-size: 16px;
}
q {
  font-style: italic;
}
span.must {
  color: #ef476f;
}
span.should {
  color: #ACCBE0;
}
span.could {
  color: #ffd166;
}
h1 a, h2 a, h3 a, h4 a, h5 a, h6 a {
  border-bottom: none;
}
h1 code, h2 code, h3 code, h4 code, h5 code, h6 code {
  font-size: inherit;
}
a {
  text-decoration: none;
  color: inherit;
  position: relative;
  transition: color 0.3s ease, opacity 0.3s ease;
}
a > img {
  vertical-align: top;
}
a:not(.no-external)[target=_blank]:after {
  width: 14px;
  height: 14px;
  content: " ";
  display: inline-block;
  background-color: #0D112B;
  -webkit-mask-image: url("external.49106d9c.svg");
  mask-image: url("external.49106d9c.svg");
  transition: background-color 0.3s ease;
}
a.underlined {
  padding: 0 3px;
  box-shadow: inset 0 -1px 0px 0px #ef476f;
  transition: box-shadow 0.15s ease, color 0.15s ease;
}
a.underlined:hover {
  color: #fff !important;
  box-shadow: inset 0 -26px 0 0 #ef476f;
}
a.colorful:hover {
  color: #F22F46;
}
a.colorful:hover:after {
  background-color: #F22F46;
  background-color: #FFF;
}
a.transparency:hover {
  opacity: 0.6;
}
h1 > a, h2 > a, h3 > a, h4 > a, h5 > a, h6 > a {
  position: relative;
}
h1 > a:before, h2 > a:before, h3 > a:before, h4 > a:before, h5 > a:before, h6 > a:before {
  position: absolute;
  top: 50%;
  transform: translate(calc(-100% - 6px), -50%);
  transition: opacity 0.3s ease;
  line-height: initial;
  height: initial !important;
  width: 16px !important;
  bottom: auto !important;
  background-color: transparent !important;
  opacity: 0 !important;
