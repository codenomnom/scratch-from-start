{
  "name": "scratch-from-start",
  "version": "0.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm-run-all scss --parallel scss:watch serve",
    "build": "npm-run-all copy scss",
    "copy": "node bin/copy.js",
    "serve": "live-server src/",
    "scss": "node-sass --output-style compressed --linefeed lf src/styles/main.scss src/styles/main.css",
    "scss:watch": "node-sass -w src/styles -o src/styles",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:codenomnom/scratch-froms-tart.git"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "fs-extra": "^10.0.0",
    "live-server": "^1.2.1",
    "node-sass": "^6.0.1",
    "npm-run-all": "^4.1.5"
  }
}
